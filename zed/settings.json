{
  "diagnostics": {
    "button": false
  },
  "diff_view_style": "split",
  "proxy": "",
  "project_panel": {
    "git_status_indicator": true,
    "entry_spacing": "standard",
    "dock": "left"
  },
  "outline_panel": {
    "button": false,
    "dock": "left"
  },
  "collaboration_panel": {
    "button": false,
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "terminal": {
    "font_weight": 400.0,
    "font_family": ".ZedMono",
    "shell": "system"
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "tab_size": 2,
  "toolbar": {
    "quick_actions": false,
    "breadcrumbs": false
  },
  "ui_font_family": ".ZedMono",
  "agent_servers": {
    "pi-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry"
    }
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "profiles": {
    },
    "default_model": {
      "enable_thinking": false,
      "provider": "opencode",
      "model": "go/kimi-k2.6"
    },
    "commit_message_model": {
      "provider": "anthropic",
      "model": "claude-haiku-4-5-latest"
    }
  },
  "language_models": {
    "opencode": {
      "show_free_models": false,
      "show_zen_models": false
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "ui_font_size": 14.0,
  "buffer_font_size": 12.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Tokyo Night"
  },
  "format_on_save": "off",
  "formatter": "prettier"
}
