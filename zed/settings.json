{
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "terminal": {
    "font_weight": 400.0,
    "font_family": ".ZedMono",
    "shell": "system"
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "tab_size": 2,
  "toolbar": {
    "quick_actions": false,
    "breadcrumbs": false
  },
  "ui_font_family": ".ZedMono",
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry",
      "env": {
        "OPENCODE_DEFAULT_MODEL": "opencode-go/kimi-k2.5"
      }
    }
  },
  "agent": {
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "anthropic",
      "model": "claude-sonnet-4-6-latest"
    },
    "commit_message_model": {
      "provider": "anthropic",
      "model": "claude-haiku-4-5-latest"
    }
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato"
  },
  "ui_font_size": 14.0,
  "buffer_font_size": 12.0,
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato"
  },
  "format_on_save": "off",
  "formatter": "prettier"
}
